# ===== LLM 配置 =====
# 大语言模型 API Key，如 OpenAI Key 或兼容的国产模型 API 密钥
LLM_API_KEY=your-api-key-here
# 大模型 API 的 Base URL，默认是 OpenAI 官方。如果使用国产大模型（如 DeepSeek 等），请修改为对应的 URL
LLM_BASE_URL=https://api.openai.com/v1
# 使用的具体模型名称，例如 gpt-4o, deepseek-chat, qwen-max 等
LLM_MODEL=gpt-4o

# ===== 数据库配置 =====
# SQLite 本地数据库的存储路径
DATABASE_URL=sqlite:///./data/briefing.db

# ===== 数据采集配置 =====
# OPML 订阅源配置文件的路径
RSS_OPML_PATH=data_source/rss.opml
# 定时高频抓取 RSS 订阅源的间隔时间（分钟），对应 Loop A
RSS_FETCH_INTERVAL_MINUTES=30
# 每次抓取时向后回溯的有效时间（分钟），用于过滤掉太旧的新闻。通常设置为抓取间隔的 2~4 倍以防漏抓
RSS_LOOKBACK_MINUTES=120
# 调用大模型 API 进行总结和打分时的并发数，可根据你 API 的并发限制调整
LLM_CONCURRENCY=5

# ===== V0.3 个性化配置 =====
# 注入给 LLM 的私人画像，这段文字将直接出现在打分 Prompt 中
# 请详细描述你的职业角色、技术兴趣、不感兴趣的内容等
USER_PERSONA=我是一名关注 AI 发展的技术人员，偏好开源项目和硬核技术解析，不看软文。

# ===== V0.3 去重配置 =====
# Loop A 标题相似度硬拦截阈值（0.0-1.0），越高越严格
TITLE_SIMILARITY_THRESHOLD=0.85

# ===== V0.3 上下文配置 =====
# Loop B 生成摘要时，向 LLM 喂入过去几天的历史早报作为短期记忆
CONTEXT_LOOKBACK_DAYS=3
# 历史上下文最大注入条数（防止 Token 溢出）
CONTEXT_MAX_ITEMS=45

# ===== V0.3 数据清理配置 =====
# 原始新闻数据保留天数
CLEANUP_RETENTION_DAYS=7
# 清理任务执行时间
CLEANUP_HOUR=3
CLEANUP_MINUTE=0

# ===== 推送与打分阈值 =====
# 满分 100 分。当单条新闻评分 >= 该值时，会被判定为“重大突发”，立即推送到钉钉
INSTANT_PUSH_THRESHOLD=90
# 当单条新闻评分 >= 该值时，才会被保留并写入数据库，用于后续汇总晨报
FETCH_STORE_THRESHOLD=60
# DuckDuckGo 搜索扩展的阈值：评分 >= 此阈值的重大新闻，系统会调用搜索引擎补充相关背景知识
DDGS_TRIGGER_THRESHOLD=70

# ===== 调度配置 =====
# 每日精选晨报（Loop B）生成的固定小时数（0-23）
SCHEDULE_HOUR=8
# 每日精选晨报生成的固定分钟数（0-59）
SCHEDULE_MINUTE=30
# 定时任务触发时的时区基准
TIMEZONE=Asia/Shanghai

# ===== 推送配置（Phase 2） =====
# 本地或线上前端网站的 URL，用于在钉钉消息卡片中生成“查看详情”跳转链接
FRONTEND_BASE_URL=http://localhost:5173
# 钉钉群机器人的 Webhook 地址（如需钉钉推送则必填）
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
# 钉钉机器人安全设置 —— 自定义关键词模式（推荐）
# 在钉钉后台设置"自定义关键词"后，所有推送消息会自动包含此关键词以通过安全校验
DINGTALK_KEYWORD=【日报】
# 钉钉机器人安全设置 —— 加签模式（可选，与关键词模式可并存）
# 如果在钉钉后台开启了"加签"安全模式则需要填写
# DINGTALK_SECRET=SECxxxxxxxxxxxxxxxx
# 钉钉推送 API 请求的超时时间（秒）
# DINGTALK_TIMEOUT=10
# 发送每日晨报到钉钉时，卡片上最多展示的新闻摘要条数上限
# DINGTALK_SUMMARY_MAX_ITEMS=20
