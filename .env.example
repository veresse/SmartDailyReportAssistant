# ===== LLM 配置 =====
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ===== 数据库配置 =====
DATABASE_URL=sqlite:///./data/briefing.db

# ===== 数据采集配置 =====
COLLECT_MAX_ITEMS=20
COLLECTOR_CONCURRENCY=3
LLM_CONCURRENCY=5
AI_FILTER_ENABLED=true
AI_FILTER_BATCH_SIZE=50
AI_FILTER_TARGET_AUDIENCE=AI 开发者、AI 研究员和关注大模型应用的技术团队

# ===== 调度配置 =====
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Shanghai

# ===== 推送配置（Phase 2） =====
FRONTEND_BASE_URL=http://localhost:5173
# FEISHU_WEBHOOK_URL=
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
# DINGTALK_SECRET=SECxxxxxxxxxxxxxxxx
# DINGTALK_TIMEOUT=10
# DINGTALK_SUMMARY_MAX_ITEMS=20
